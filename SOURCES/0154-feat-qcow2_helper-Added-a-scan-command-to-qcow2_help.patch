+
+/*
+ * Strncpy variant that guarantees to terminate the string
+ */
+static inline char *
+safe_strncpy(char *dest, const char *src, size_t n)
+{
+	char *pdest;
+	pdest = strncpy(dest, src, n - 1);
+	if (n > 0)
+		dest[n - 1] = '\0';
+	return pdest;
+}
