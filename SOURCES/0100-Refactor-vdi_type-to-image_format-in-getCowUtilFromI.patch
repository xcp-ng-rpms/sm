From f8292778c35293bd1fd0cefdaf82f4ba5e3f35f5 Mon Sep 17 00:00:00 2001
From: Damien Thenot <damien.thenot@vates.tech>
Date: Mon, 3 Feb 2025 13:22:27 +0100
Subject: [PATCH] Refactor vdi_type to image_format in
 getCowUtilFromImageFormat for QCOW2

Signed-off-by: Damien Thenot <damien.thenot@vates.tech>
---
 drivers/cowutil.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/cowutil.py b/drivers/cowutil.py
index 5d6b9397..49e19d1c 100755
--- a/drivers/cowutil.py
+++ b/drivers/cowutil.py
@@ -329,7 +329,7 @@ def getCowUtilFromImageFormat(image_format: ImageFormat) -> CowUtil:
     if image_format in (ImageFormat.RAW, ImageFormat.VHD):
         return vhdutil.VhdUtil()
 
-    if getImageFormatFromVdiType(vdi_type) == ImageFormat.QCOW2:
+    if image_format == ImageFormat.QCOW2:
         return qcow2util.QCowUtil()
 
     assert False, f"Unsupported VDI type: {vdi_type}"
