         mock_vdi.getSizePhys.return_value = 10 * MEGA
         mock_vdi.parent = mock_parent
 
-        sr._doCoalesceLeaf(mock_vdi)
+        sr._doCoalesceLeaf(mock_vdi, False)
 
         self.assertNotIn('vhd-parent', mock_parent.delConfig.call_args)
 
